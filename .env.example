# ConnectSaver — Environment Variables
# Provider: Dodo Payments (PIVOT-01 2026-05-29)
# Single source of truth: _workspace/01_architecture.md §10
# Copy this file to .env.local for local dev. Never commit real values.
#
# Visibility convention:
#   NEXT_PUBLIC_*  -> shipped to the browser bundle
#   anything else  -> server-only (Route Handlers / RSC / Middleware)

# ============================================================
# Public (browser-exposed)
# ============================================================

# Supabase — from Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App URL — used by OAuth redirect, Dodo Payments success/cancel URLs
# Local dev: http://localhost:3000
# Production: https://app.connectsaver.com (set in Vercel env per-environment)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Dodo Payments — Product IDs for the three plan tiers.
# Issued in Dodo Dashboard > Products. Not secrets (they appear in the
# hosted checkout URL), so NEXT_PUBLIC_* prefix is correct.
NEXT_PUBLIC_DODO_PRODUCT_SINGLE=
NEXT_PUBLIC_DODO_PRODUCT_WEEKLY=
NEXT_PUBLIC_DODO_PRODUCT_MONTHLY=

# Sentry (client) — same DSN as server, just exposed to browser bundle
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================
# Server-only (NEVER prefix with NEXT_PUBLIC_)
# ============================================================

# Supabase service_role — RLS bypass, used by lib/supabase/admin.ts only
# Source: Supabase Project Settings > API > service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI — from platform.openai.com > API keys
OPENAI_API_KEY=

# Dodo Payments — server-side API + Standard Webhooks signing secret.
# DODO_API_KEY:        Dodo Dashboard > Developers > API keys. test_mode keys
#                      are accepted in local/preview; live_mode in production.
# DODO_WEBHOOK_SECRET: Dodo Dashboard > Developers > Webhooks > [endpoint] >
#                      Signing secret. Used by the Standard Webhooks library
#                      to verify the `webhook-id` / `webhook-timestamp` /
#                      `webhook-signature` headers on /api/webhooks/dodo.
DODO_API_KEY=
DODO_WEBHOOK_SECRET=

# Vercel KV — auto-injected by `vercel link` + Storage > KV > Connect Project.
# Keep all four. The read-only token is split out so that any client-side
# usage (none today, but reserved for future RSC reads) cannot mutate KV.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Sentry (server) — same value as NEXT_PUBLIC_SENTRY_DSN is acceptable
SENTRY_DSN=

# Fallback version when system_prompts table query fails. Pinned to 1 at MVP.
SYSTEM_PROMPT_VERSION=1
